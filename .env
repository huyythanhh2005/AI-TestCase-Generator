OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Model dự phòng nếu model chính lỗi/chưa pull (phân cách bằng dấu phẩy)
# OLLAMA_FALLBACK_MODELS=qwen2.5,gemma2

# Context window gửi cho model. Tăng nếu máy đủ RAM/VRAM và cần xử lý
# website nhiều feature; giảm nếu máy yếu để chạy nhanh hơn.
OLLAMA_NUM_CTX=8192
# Giữ model trong RAM/VRAM giữa các lần gọi để không phải load lại
OLLAMA_KEEP_ALIVE=30m

TEMPERATURE=0.2
TOP_P=0.9

# Nâng lên 6144 để fix bug "chỉ sinh được 1-2 test case/batch" do output
# bị cắt cụt giữa chừng trên máy CPU-only/model nhỏ (xem config.py).
MAX_OUTPUT_TOKENS=6144
MAX_RETRY=3
# Nâng lên 600s: tốc độ sinh token phụ thuộc CPU/GPU máy chạy, batch
# TESTCASE_CHUNK_SIZE lớn có thể cần nhiều thời gian hơn 180s mặc định.
REQUEST_TIMEOUT=600

# Batch size cho mỗi lần gọi LLM (model cục bộ không giới hạn quota nên
# có thể để lớn hơn cloud, giảm số round-trip -> nhanh hơn)
LLM_CHUNK_SIZE=5
# generate_testcases() sinh nhiều loại test trong 1 lần gọi -> batch nhỏ
# hơn để giữ chất lượng JSON ổn định.
TESTCASE_CHUNK_SIZE=3

HEADLESS=true
PAGE_TIMEOUT=60000
WAIT_TIME=2000

MIN_TESTCASE=30

# excel | json | jira | testrail
EXPORT_TARGET=excel
AUTO_OPEN_EXCEL=true

# Chỉ cần điền nếu EXPORT_TARGET=jira
# JIRA_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=

# Chỉ cần điền nếu EXPORT_TARGET=testrail
# TESTRAIL_URL=
# TESTRAIL_EMAIL=
# TESTRAIL_API_KEY=
# TESTRAIL_PROJECT_ID=
# TESTRAIL_SUITE_ID=

DEBUG=true
LOG_LEVEL=INFO