OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODELS=

OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=30m

TEMPERATURE=0.2
TOP_P=0.9
REPEAT_PENALTY=1.1
OLLAMA_SEED=42

OLLAMA_NUM_THREAD=12
OLLAMA_NUM_GPU=999
OLLAMA_NUM_BATCH=512

OLLAMA_NUM_PREDICT=6144
MAX_OUTPUT_TOKENS=6144
MAX_RETRY=3
REQUEST_TIMEOUT=600

LLM_CHUNK_SIZE=5
TESTCASE_CHUNK_SIZE=3

HEADLESS=true
PAGE_TIMEOUT=60000
WAIT_TIME=2000

MAX_PAGES=5
CRAWL_INTERNAL_PAGES=false

MIN_TESTCASE=30
REMOVE_DUPLICATE=true
STRICT_GROUNDING=true

ENABLE_NEGATIVE_TEST=true
ENABLE_BOUNDARY_TEST=true
ENABLE_EXCEPTION_TEST=true
ENABLE_SECURITY_TEST=true
ENABLE_ACCESSIBILITY_TEST=true
ENABLE_PERFORMANCE_TEST=true
ENABLE_API_TEST=true

EXPORT_TARGET=excel
AUTO_OPEN_EXCEL=true

JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Test

TESTRAIL_URL=
TESTRAIL_EMAIL=
TESTRAIL_API_KEY=
TESTRAIL_PROJECT_ID=
TESTRAIL_SUITE_ID=

DEBUG=true
LOG_LEVEL=INFO
